# ===================================================
#  ERPNext / HegyesiHQ – sablon kornyezeti valtozok
# ---------------------------------------------------
#  Masold .env-be: cp .env.example .env  (es toltsd ki!)
#  A valodi .env-et SOHA ne commitold!
#
#  Ha a Portainer Web Editorbol uzemelteted a stacket
#  (jelenlegi setup), ez a fajl CSAK referenciakent kell –
#  a tenyleges ertekek a Portainer "Environment variables"
#  szekciojaban vannak.
# ===================================================

# --- Image ---
# Privat image GHCR-rol:
IMAGE=ghcr.io/szricsi0917/hegyesihq-engine
TAG=v16

# --- Site ---
SITE_NAME=portal.hegyesihq.eu

# --- Jelszavak ---
# FONTOS: docker-compose escape:
#   - Portainer Environment variables mezoben:  '$' helyett '$$'
#   - .env fajlban (ez a fajl):                 '$' valtozatlan
DB_PASSWORD=ERTEK_IDE
ERPNEXT_ADMIN_PASSWORD=ERTEK_IDE
