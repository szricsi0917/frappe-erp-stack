# ===================================================
#  Frappe ERP Stack – környezeti változó sablon
# ---------------------------------------------------
#  Másold ezt a fájlt .env-be, és töltsd ki:
#     cp .env.example .env
#
#  A valódi .env-et SOHA ne commitold gitbe!
# ===================================================

# --- Image ---
# A publikus image a GHCR-en (alapértelmezett):
IMAGE=ghcr.io/szricsi0917/frappe-erp-stack
TAG=v16

# --- Site ---
# A teljes domain név, ahol a rendszer elérhető lesz.
SITE_NAME=erp.example.com

# --- Jelszavak ---
# FIGYELEM a $ karakterre:
#   - docker-compose .env fájlban: $ valódi $-t jelent (nem kell escape-elni),
#   - Portainer "Environment variables" UI-ban: $ → $$ (escape-elni kell).
DB_PASSWORD=cseréld-ki-erős-jelszóra
ADMIN_PASSWORD=cseréld-ki-erős-jelszóra

# --- Host portok ---
# A frontend (nginx) publikus HTTP portja a hoston.
HTTP_PORT=8080

# --- Volumeok / bind mountok ---
# Alapértelmezetten a "./data" mappa a compose mellett.
# Production rendszereken állítsd át tartós tárhelyre, pl. /opt/frappe/...
SITES_DIR=./data/sites
LOGS_DIR=./data/logs
DB_DIR=./data/db
REDIS_QUEUE_DIR=./data/redis-queue
UPLOADS_PUBLIC_DIR=./data/uploads/public
UPLOADS_PRIVATE_DIR=./data/uploads/private

# --- Teljesítmény ---
# A MariaDB InnoDB bufferje. Állítsd a szabad RAM-hoz: ~50%-a egy dedikált gépen.
INNODB_BUFFER_POOL_SIZE=2G

# A Gunicorn (backend) workerei. Ajánlott: 2 × CPU + 1.
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# A frontend (nginx) maximális body mérete fájlfeltöltéskor.
CLIENT_MAX_BODY_SIZE=20m
